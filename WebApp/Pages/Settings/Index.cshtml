@page
@model DeployManager.Pages.Settings.IndexModel
@{ ViewData["Title"] = "Settings"; ViewData["ActivePage"] = "Settings"; }

@if (!string.IsNullOrEmpty(Model.SaveResult))
{
    <div class="alert @(Model.SaveOk ? "alert-success" : "alert-danger") alert-dismissible mb-4">
        @Model.SaveResult
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
<div class="col-lg-8">

<form method="post">
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-building me-2"></i>Organisation</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Organisation name</label>
            <input asp-for="Cfg.OrgName" class="form-control" placeholder="Contoso IT" />
            <div class="form-text">Shown in sidebar and page title.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Computer name prefix</label>
            <input asp-for="Cfg.ComputerPrefix" class="form-control" placeholder="CORP-" />
            <div class="form-text">Suggested prefix when creating deployment jobs.</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-server me-2"></i>Server</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Static file server URL</label>
            <input asp-for="Cfg.DeployServerUrl" class="form-control font-monospace" placeholder="http://192.168.1.10:8080" />
            <div class="form-text">Serves WIM images and HTTP job files to WinPE clients (port 8080).</div>
        </div>
        <div class="mb-3">
            <label class="form-label">API / web app URL</label>
            <input asp-for="Cfg.ApiServerUrl" class="form-control font-monospace" placeholder="https://192.168.1.10:8090" />
            <div class="form-text">This web app (port 8090). Used by WinPE and PostInstall scripts. <strong>Must be <code>https://</code></strong> — the API is HTTPS-only; an <code>http://</code> value is corrected automatically on save.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Server IP address</label>
            <input asp-for="Cfg.ServerIp" class="form-control font-monospace" placeholder="192.168.1.10" />
            <div class="form-text">Used in DHCP / TFTP configuration instructions only.</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-diagram-3 me-2"></i>Active Directory</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Domain FQDN</label>
            <input asp-for="Cfg.DomainFqdn" class="form-control font-monospace" placeholder="corp.contoso.com" />
        </div>
        <div class="mb-3">
            <label class="form-label">Service account UPN</label>
            <div class="d-flex gap-2 align-items-start">
                <input asp-for="Cfg.ServiceAccountUpn" class="form-control" placeholder="svc-osdeploy@corp.contoso.com" />
                <button type="button" id="testDomainBtn" class="btn btn-outline-secondary btn-sm" style="white-space:nowrap;margin-top:0">
                    <i class="bi bi-plug me-1"></i>Test
                </button>
            </div>
            <div id="testDomainResult" class="mt-1" style="font-size:.82rem;min-height:1.2em"></div>
            <div class="form-text">Account used by djoin to pre-stage computer objects.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Service account password</label>
            @if (Model.ServiceAccountPasswordSet)
            {
                <div class="form-text text-success mb-1"><i class="bi bi-shield-lock-fill me-1"></i>Password is set (encrypted at rest)</div>
            }
            else
            {
                <div class="form-text text-warning mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>No password set</div>
            }
            <input asp-for="Cfg.ServiceAccountPassword" type="password" class="form-control"
                   placeholder="@(Model.ServiceAccountPasswordSet ? "Enter new password to replace" : "Enter service account password")"
                   autocomplete="new-password" />
        </div>
        <div class="mb-3">
            <label class="form-label">Default computer OU</label>
            <input asp-for="Cfg.DefaultComputerOU" class="form-control font-monospace"
                   placeholder="OU=Computers,DC=corp,DC=contoso,DC=com" />
            <div class="form-text">Fallback OU when no site match found.</div>
        </div>
        <div class="mb-1">
            <div class="form-check form-switch mb-2">
                <input asp-for="Cfg.RecreateComputerAccountOnReuseFailure" type="checkbox" class="form-check-input" role="switch" />
                <label class="form-check-label" asp-for="Cfg.RecreateComputerAccountOnReuseFailure">
                    Recreate computer object when re-use is blocked
                </label>
            </div>
            <div class="form-text">
                When re-imaging a machine that already has an Active Directory computer object, Deploy Manager
                normally <strong>re-uses</strong> that object. Since <strong>KB5020276</strong>, some domain
                controllers block re-use of an existing account (provisioning fails with error
                <code>2732</code> and the machine can't domain-join). With this enabled, Deploy Manager
                <strong>deletes and recreates</strong> the object in that case, so re-imaging still succeeds.
                <div class="alert alert-warning py-2 px-3 mt-2 mb-0" style="font-size:.82rem">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    Deleting a computer object also removes its escrowed <strong>BitLocker recovery keys</strong>
                    and its <strong>security-group memberships</strong>. It only triggers when a re-use is
                    actually blocked, and the deleted object is immediately recreated — but leave this
                    <strong>off</strong> unless your domain controllers reject account re-use.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-usb-drive me-2"></i>WinPE</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Local admin account name</label>
            <input asp-for="Cfg.WinpeLocalAccount" class="form-control" placeholder="LocalDeploy" />
            <div class="form-text">Temporary local account created during imaging. Removed post-OSD in hardening step.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Local admin password</label>
            @if (Model.WinpeLocalPasswordSet)
            {
                <div class="form-text text-success mb-1"><i class="bi bi-shield-lock-fill me-1"></i>Password is set (encrypted at rest)</div>
            }
            else
            {
                <div class="form-text text-warning mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>No password set</div>
            }
            <input asp-for="Cfg.WinpeLocalPassword" type="password" class="form-control"
                   placeholder="@(Model.WinpeLocalPasswordSet ? "Enter new password to replace" : "Enter local admin password")"
                   autocomplete="new-password" />
        </div>
        <div class="mb-3">
            <label class="form-label">Default timezone</label>
            <input asp-for="Cfg.DefaultTimezone" class="form-control" placeholder="Eastern Standard Time" />
            <div class="form-text">Windows timezone ID applied when no per-site timezone is set. See <a href="https://learn.microsoft.com/en-us/windows-hardware/manufacture/desktop/default-time-zones" target="_blank">timezone IDs</a>.</div>
        </div>
        <div class="mb-3">
            <label class="form-label">Default locale</label>
            <input asp-for="Cfg.DefaultLocale" class="form-control" placeholder="en-US" />
            <div class="form-text">Windows locale tag used in unattend.xml (keyboard, UI language, regional formats). e.g. <code>en-US</code>, <code>en-GB</code>, <code>en-AU</code>. Can be overridden per site.</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-share me-2"></i>Software Delivery</div>
    <div class="card-body">
        <div class="form-check form-switch mb-2">
            <input asp-for="Cfg.EnableBranchCache" type="checkbox" class="form-check-input" role="switch" />
            <label class="form-check-label" asp-for="Cfg.EnableBranchCache">
                Enable BranchCache (site-local caching)
            </label>
        </div>
        <div class="form-text">
            When enabled, PostInstall activates <strong>BranchCache Distributed Cache</strong> mode on
            each newly imaged machine and uses <strong>BITS</strong> (instead of
            <code>Invoke-WebRequest</code>) for HTTP software downloads. Machines at the same site
            then serve cached packages to each other, cutting repeat WAN downloads to near-zero.
            <br /><br />
            <strong>Pre-requisites:</strong> at least one machine at each remote site must already be
            running with BranchCache enabled before imaging begins, so it can act as a peer source.
            No hosted-cache server or WSUS infrastructure is required for Distributed Cache mode.
        </div>
        <hr />
        <div class="mb-1">
            <label class="form-label">Software install timeout (minutes)</label>
            <input asp-for="Cfg.SoftwareInstallTimeoutMinutes" type="number" min="1" max="1440"
                   class="form-control" style="max-width:160px" />
            <div class="form-text">
                Maximum time a single software installer may run during post-install before it is
                <strong>terminated and recorded as a timeout failure</strong>, so one hung installer can't
                stall the whole deployment. The deployment then continues to the next package. Default
                <strong>60</strong>. Raise it for large or slow installers; lower it for a tighter
                unattended run. Applies to newly patched boot images.
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-shield-lock me-2"></i>BitLocker Drive Encryption</div>
    <div class="card-body">
        <div class="form-check form-switch mb-2">
            <input asp-for="Cfg.BitLockerEnable" type="checkbox" class="form-check-input" role="switch" />
            <label class="form-check-label" asp-for="Cfg.BitLockerEnable">
                Enable BitLocker after imaging
            </label>
        </div>
        <div class="form-text mb-3">
            After the software phase, encrypt the machine with BitLocker. Requires a TPM (present on all
            Secure Boot hardware) — machines without a ready TPM are skipped and reported. Applies to newly
            patched boot images.
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Volumes to encrypt</label>
                <select asp-for="Cfg.BitLockerVolumes" class="form-select">
                    <option value="os">OS drive only</option>
                    <option value="osdata">OS drive + all fixed data drives</option>
                    <option value="specific">Specific volumes (by label or letter)</option>
                </select>
                <div class="form-text">"OS + all fixed data drives" auto-detects every fixed, non-OS volume — no drive letters needed. Removable drives are never encrypted.</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Specific volumes</label>
                <input asp-for="Cfg.BitLockerSpecificVolumes" class="form-control" placeholder="DATA;E" />
                <div class="form-text">Used only with "Specific volumes". Semicolon-separated volume labels or drive letters.</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Encryption method</label>
                <select asp-for="Cfg.BitLockerEncryptionMethod" class="form-select">
                    <option value="XtsAes256">XTS-AES 256 (recommended)</option>
                    <option value="XtsAes128">XTS-AES 128</option>
                </select>
            </div>
            <div class="col-md-6 d-flex align-items-end pb-2">
                <div class="form-check">
                    <input asp-for="Cfg.BitLockerUsedSpaceOnly" type="checkbox" class="form-check-input" />
                    <label class="form-check-label" asp-for="Cfg.BitLockerUsedSpaceOnly">Encrypt used space only (faster)</label>
                </div>
            </div>
        </div>

        <hr />
        <label class="form-label d-block mb-2">Recovery-key escrow <span class="text-secondary" style="font-weight:400">(enable one or more)</span></label>
        <div class="form-check mb-1">
            <input asp-for="Cfg.BitLockerBackupToAd" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="Cfg.BitLockerBackupToAd">Active Directory (AD DS)</label>
        </div>
        <div class="form-text mb-2" style="margin-left:1.6rem">
            Domain-joined machines. Deploy Manager backs the recovery key up to the computer object in AD DS.
        </div>
        <div class="form-check mb-1" style="margin-left:1.6rem">
            <input asp-for="Cfg.BitLockerAdBackupViaGpo" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="Cfg.BitLockerAdBackupViaGpo">AD backup is handled by my Group Policy</label>
        </div>
        <div class="form-text mb-2" style="margin-left:3.2rem">
            Tick this if you already run the BitLocker GPO <em>&ldquo;Store BitLocker recovery information in
            Active Directory Domain Services&rdquo;</em>. That policy escrows the key at encryption time and
            refuses the manual backup, so Deploy Manager skips its own attempt and trusts the GPO (rather than
            reporting a false failure).
        </div>
        <div class="form-check mb-1">
            <input asp-for="Cfg.BitLockerBackupToEntra" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="Cfg.BitLockerBackupToEntra">Entra ID / Intune</label>
        </div>
        <div class="form-text mb-2" style="margin-left:1.6rem">
            For Entra-joined or hybrid-joined machines. Note: a pure Autopilot machine isn't Entra-joined
            until OOBE, so BitLocker for those is usually better handled by an Intune policy after enrollment.
        </div>
        <div class="form-check mb-1">
            <input asp-for="Cfg.BitLockerSaveToShare" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="Cfg.BitLockerSaveToShare">Save to a network share</label>
        </div>
        <div class="mb-2" style="margin-left:1.6rem">
            <input asp-for="Cfg.BitLockerSharePath" class="form-control font-monospace"
                   placeholder="\\server\BitLockerKeys" style="max-width:420px" />
            <div class="form-text">Writes each recovery key to <code>&lt;ComputerName&gt;_&lt;drive&gt;.txt</code> on the share. The machine account needs write access.</div>
        </div>
        <div class="alert alert-danger py-2 px-3 mb-3" style="font-size:.82rem">
            <i class="bi bi-shield-exclamation me-1"></i>
            The share option stores the recovery key in <strong>clear text</strong>. Restrict the share to
            administrators only, and prefer AD or Entra escrow where available.
        </div>

        <div class="form-check mb-2">
            <input asp-for="Cfg.BitLockerRequireEscrow" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="Cfg.BitLockerRequireEscrow">
                Require successful escrow (flag the job if no target accepts the key)
            </label>
        </div>
        <div class="alert alert-warning py-2 px-3 mb-0" style="font-size:.82rem">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            With this on, if the recovery key can't be escrowed to any enabled target the job is marked
            <strong>failed</strong> for attention. The drive is left encrypted and functional &mdash; it is
            never auto-decrypted &mdash; so you can escrow the key manually or investigate.
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-activity me-2"></i>Job Monitoring</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Inactivity timeout (minutes)</label>
                <input asp-for="Cfg.JobInactivityTimeoutMinutes" type="number" min="5" max="1440"
                       class="form-control" style="max-width:160px" />
                <div class="form-text">
                    A job that's imaging with <strong>no progress or heartbeat</strong> for this long is marked
                    <em>timed out</em>. It's activity-based, so a slow-but-progressing deployment (large WIM over
                    WAN, long installer) is never falsely failed. Default <strong>30</strong>.
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Maximum duration (minutes)</label>
                <input asp-for="Cfg.JobMaxDurationMinutes" type="number" min="30" max="2880"
                       class="form-control" style="max-width:160px" />
                <div class="form-text">
                    Absolute ceiling — a job is timed out after this long regardless of activity, as a backstop.
                    Default <strong>480</strong> (8 hours).
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-microsoft me-2"></i>Entra ID single sign-on</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Sign-in method</label>
            <select asp-for="Cfg.AuthMode" class="form-select">
                <option value="local">Breakglass only (local password)</option>
                <option value="entra">Entra ID SSO (breakglass retained as fallback)</option>
            </select>
            <div class="form-text">
                Entra SSO needs the Tenant ID, Client ID and secret below, plus users registered under
                <a asp-page="/Users/Index">Users</a>.
            </div>
            <div class="alert alert-warning py-2 px-3 mt-2 mb-0" style="font-size:.82rem">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                <strong>Service restart required.</strong> Changes to the sign-in method, Tenant ID, Client ID or secret only take effect after restarting the Deploy Manager service (via the tray app or <code>sc.exe</code>).
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Directory (tenant) ID</label>
            <input asp-for="Cfg.EntraTenantId" class="form-control font-monospace" placeholder="00000000-0000-0000-0000-000000000000" />
        </div>
        <div class="mb-3">
            <label class="form-label">Application (client) ID</label>
            <input asp-for="Cfg.EntraClientId" class="form-control font-monospace" placeholder="00000000-0000-0000-0000-000000000000" />
        </div>
        <div class="mb-3">
            <label class="form-label">Client secret</label>
            @if (Model.EntraSecretSet)
            {
                <div class="form-text text-success mb-1"><i class="bi bi-shield-lock-fill me-1"></i>Secret is set (encrypted at rest)</div>
            }
            else
            {
                <div class="form-text text-warning mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>No secret set</div>
            }
            <input asp-for="Cfg.EntraClientSecret" type="password" class="form-control" autocomplete="new-password"
                   placeholder="@(Model.EntraSecretSet ? "Enter new secret to replace" : "Paste the client secret value")" />
        </div>
        <div class="mb-1">
            <label class="form-label">Redirect URI (register this in Entra)</label>
            <input class="form-control font-monospace" readonly
                   value="@(string.IsNullOrEmpty(Model.Cfg.ApiServerUrl) ? "https://<your-host>:8090" : Model.Cfg.ApiServerUrl)/signin-oidc" />
            <div class="form-text">Add as a <strong>Web</strong> redirect URI on the app registration — one per host you sign in from (e.g. the CNAME).</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-cloud-arrow-up me-2"></i>Intune Autopilot</div>
    <div class="card-body">
        <div class="form-check form-switch mb-2">
            <input asp-for="Cfg.IntuneAutoRegister" type="checkbox" class="form-check-input" role="switch" />
            <label class="form-check-label" asp-for="Cfg.IntuneAutoRegister">
                Automatically register devices in Intune Autopilot
            </label>
        </div>
        <div class="form-text">
            When enabled, Deploy Manager automatically registers Autopilot devices with
            Intune via the Microsoft Graph API after collecting the hardware hash. It checks
            if the device is already registered (by serial number) and skips re-registration,
            updating the group tag if it has changed. Requires the Entra app registration
            above to have the <code>DeviceManagementServiceConfig.ReadWrite.All</code>
            application permission (with admin consent).
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-envelope me-2"></i>Email Notifications</div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">SMTP host</label>
                <input asp-for="Cfg.SmtpHost" class="form-control font-monospace" placeholder="smtp.example.com" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Port</label>
                <input asp-for="Cfg.SmtpPort" type="number" class="form-control" />
            </div>
            <div class="col-md-3 d-flex align-items-end pb-1">
                <div class="form-check">
                    <input asp-for="Cfg.SmtpStartTls" type="checkbox" class="form-check-input" />
                    <label class="form-check-label" asp-for="Cfg.SmtpStartTls">STARTTLS / SSL</label>
                </div>
            </div>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">Username</label>
                <input asp-for="Cfg.SmtpUsername" class="form-control" placeholder="notify@example.com" autocomplete="off" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Password</label>
                @if (Model.SmtpPasswordSet)
                {
                    <div class="form-text text-success mb-1"><i class="bi bi-shield-lock-fill me-1"></i>Password is set (encrypted at rest)</div>
                }
                <input asp-for="Cfg.SmtpPassword" type="password" class="form-control"
                       placeholder="@(Model.SmtpPasswordSet ? "Enter new password to replace" : "SMTP password")"
                       autocomplete="new-password" />
            </div>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">From address</label>
                <input asp-for="Cfg.SmtpFrom" class="form-control" placeholder="deploymgr@example.com" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Notify address</label>
                <input asp-for="Cfg.NotifyEmail" class="form-control" placeholder="it-team@example.com" />
                <div class="form-text">Destination address for job notifications.</div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <div class="form-check">
                <input asp-for="Cfg.NotifyOnComplete" type="checkbox" class="form-check-input" />
                <label class="form-check-label" asp-for="Cfg.NotifyOnComplete">Notify on complete</label>
            </div>
            <div class="form-check">
                <input asp-for="Cfg.NotifyOnError" type="checkbox" class="form-check-input" />
                <label class="form-check-label" asp-for="Cfg.NotifyOnError">Notify on error</label>
            </div>
            <button type="button" id="testEmailBtn" class="btn btn-sm btn-outline-secondary ms-auto">
                <i class="bi bi-send me-1"></i>Send test email
            </button>
        </div>
        <div id="testEmailResult" class="mt-2" style="font-size:.82rem;min-height:1.2em"></div>
    </div>
</div>

<button type="submit" class="btn btn-primary">
    <i class="bi bi-check-circle me-1"></i>Save Settings
</button>
</form>

</div>

<div class="col-lg-4">
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-person-lock me-2"></i>Breakglass password</div>
        <div class="card-body">
            <p class="text-secondary" style="font-size:.82rem">
                Changes the emergency admin password accessible at <code>/auth/login</code>.
            </p>
            <form method="post" asp-page-handler="ChangeBreakglass">
                <div class="mb-2">
                    <input type="password" name="currentPassword" class="form-control form-control-sm"
                           placeholder="Current password" required autocomplete="current-password" />
                </div>
                <div class="mb-2">
                    <input type="password" name="newPassword" class="form-control form-control-sm"
                           placeholder="New password" required autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <input type="password" name="confirmPassword" class="form-control form-control-sm"
                           placeholder="Confirm new password" required autocomplete="new-password" />
                </div>
                <button class="btn btn-sm btn-outline-warning w-100">Change Password</button>
            </form>
            <div class="mt-2 text-secondary" style="font-size:.75rem">
                <i class="bi bi-info-circle me-1"></i>Min 14 chars, upper+lower+digit+special (ISM-0421)
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-map me-2"></i>Sites</div>
        <div class="card-body">
            <p class="text-secondary" style="font-size:.82rem">
                Configure subnet → site → OU mappings and per-site timezones.
            </p>
            <a asp-page="/Settings/Sites" class="btn btn-sm btn-outline-primary w-100">
                <i class="bi bi-pencil me-1"></i>Edit Sites
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-arrow-up-circle me-2"></i>Updates</div>
        <div class="card-body">
            <div class="mb-2">
                <label class="form-label" style="font-size:.8rem">GitHub releases API URL</label>
                <input asp-for="Cfg.UpdateCheckUrl" class="form-control form-control-sm font-monospace"
                       placeholder="https://api.github.com/repos/owner/repo/releases/latest" />
                <div class="form-text">Leave blank to disable update checks.</div>
            </div>
            <button type="button" id="checkUpdateBtn" class="btn btn-sm btn-outline-secondary w-100">
                <i class="bi bi-cloud-download me-1"></i>Check for updates
            </button>
            <div id="checkUpdateResult" class="mt-2" style="font-size:.82rem;min-height:1.2em"></div>
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
async function ajaxGet(url, resultEl, btn) {
    btn.disabled = true;
    resultEl.innerHTML = '<span class="text-secondary"><span class="spinner-border spinner-border-sm me-1"></span>Please wait…</span>';
    try {
        const r = await fetch(url);
        const d = await r.json();
        if (d.ok) {
            if (d.updateAvailable === false) {
                resultEl.innerHTML = `<span class="text-success"><i class="bi bi-check-circle me-1"></i>Up to date (v${d.current})</span>`;
            } else if (d.updateAvailable === true) {
                resultEl.innerHTML = `<span class="text-warning"><i class="bi bi-arrow-up-circle me-1"></i>v${d.latest} available — <a href="${d.releaseUrl}" target="_blank" rel="noopener">release notes</a></span>`;
            } else {
                resultEl.innerHTML = `<span class="text-success"><i class="bi bi-check-circle me-1"></i>${d.message}</span>`;
            }
        } else {
            resultEl.innerHTML = `<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>${d.message}</span>`;
        }
    } catch (e) {
        resultEl.innerHTML = `<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>${e.message}</span>`;
    }
    btn.disabled = false;
}

document.getElementById('testDomainBtn')?.addEventListener('click', function() {
    ajaxGet('?handler=TestDomain', document.getElementById('testDomainResult'), this);
});
document.getElementById('testEmailBtn')?.addEventListener('click', function() {
    ajaxGet('?handler=TestEmail', document.getElementById('testEmailResult'), this);
});
document.getElementById('checkUpdateBtn')?.addEventListener('click', function() {
    ajaxGet('?handler=CheckUpdate', document.getElementById('checkUpdateResult'), this);
});
</script>
}
